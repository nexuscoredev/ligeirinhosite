# Copie para .env.local (dev com `npx vercel dev`) ou cadastre no Vercel → Settings → Environment Variables

# Google login
GOOGLE_CLIENT_ID=
APP_BASE_URL=https://ligeirinhoparceiros.vercel.app
REQUIRE_LOGIN=false

# Mercado Pago (credenciais de TESTE primeiro)
MP_PUBLIC_KEY=TEST-xxxx
MP_ACCESS_TOKEN=TEST-xxxx

# Supabase — projeto ligeirinhoparceiros (org Ligeirinho Parceiros)
# Dashboard: https://supabase.com/dashboard/project/tugbsnjyvfhyvtivfhea/settings/api
SUPABASE_URL=https://tugbsnjyvfhyvtivfhea.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Ligeirinho Hub — catálogo ao vivo + resolução de perfil (Totem / Admin / Parceiro)
HUB_SUPABASE_URL=https://liszpwocwvkytzyaxvit.supabase.co
HUB_SUPABASE_ANON_KEY=
# Obrigatório para /api/catalog (sync automático com o Hub)
HUB_SUPABASE_SERVICE_ROLE_KEY=
# Cache CDN do catálogo em segundos (padrão: 300 = 5 min)
CATALOG_CACHE_SECONDS=300

# Módulo financeiro — token JWT (use string aleatória longa; fallback: SUPABASE_SERVICE_ROLE_KEY)
FINANCE_JWT_SECRET=
